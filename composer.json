{
    "name": "acidwave/laravel-sso",
    "description": "Simple PHP SSO integration for Laravel",
    "keywords": [
        "laravel",
        "sso",
        "authentication",
        "login"
    ],
    "homepage": "https://github.com/acidwave/laravel-sso",
    "license": "MIT",
    "authors": [
        {
            "name": "Timur Akmalov",
            "email": "me@acidwave.ru",
            "homepage": "https://github.com/acidwave",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^7.2.5",
        "guzzlehttp/guzzle": "^6.0|^7.0",
        "laravel/framework": "^5.5|^7.0|^8.0",
        "zefy/php-simple-sso": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Acidwave\\LaravelSSO\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Acidwave\\LaravelSSO\\SSOServiceProvider"
            ]
        }
    }
}